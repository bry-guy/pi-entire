{
  "name": "pi-entire",
  "version": "0.2.0-alpha.0",
  "description": "Entire CLI integration for pi coding agent — capture AI sessions as git-linked checkpoints",
  "keywords": ["pi-package", "pi-extension", "entire", "git", "sessions", "checkpoints"],
  "license": "MIT",
  "author": "bry-guy",
  "repository": {
    "type": "git",
    "url": "https://github.com/bry-guy/pi-entire"
  },
  "pi": {
    "extensions": ["./extensions"]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit --pretty false",
    "validate": "npm run lint && npm run test"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
